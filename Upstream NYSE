<!DOCTYPE html>
<html>
<head>
  <script src="https://www.gstatic.com/charts/loader.js"></script>
  <script>
    google.charts.load('current', {packages: ['corechart']});
    google.charts.setOnLoadCallback(drawChart);

    function drawChart() {
      var query = new google.visualization.Query(
        'https://docs.google.com/spreadsheets/d/1QqDh2RK9PPXLXUhitoPEsF6R-4wZKsEyBDCShablXYg/gviz/tq?gid=0&headers=1'
      );
      // Selezioniamo solo le colonne che ci servono: A (Data), B (sinistra), Q e S (destra)
      query.setQuery('select A, B, Q, S');
      query.send(handleQueryResponse);
    }

    function handleQueryResponse(response) {
      if (response.isError()) {
        alert('Errore: controlla che il foglio sia pubblicato sul web');
        return;
      }
      var data = response.getDataTable();

      var options = {
        title: 'Grafico 1 - Commodity Supercycle',   // ← CAMBIA CON IL TITOLO VERO
        width: '100%',
        height: 550,
        legend: {position: 'bottom'},                // cliccabile → accendi/spegni curve
        seriesType: 'line',
        vAxes: {
          0: {title: 'Scala SINISTRA (Colonna B)'},   // qui va la colonna B
          1: {title: 'Scala DESTRA (Q e S)'}          // qui vanno Q e S
        },
        series: {
          0: {targetAxisIndex: 0, color: '#e74c3c', lineWidth: 3},  // Colonna B - sinistra
          1: {targetAxisIndex: 1, color: '#3498db', lineWidth: 3},  // Colonna Q - destra
          2: {targetAxisIndex: 1, color: '#2ecc71', lineWidth: 3}   // Colonna S - destra
        },
        hAxis: {title: 'Data', format: 'dd/mm/yyyy'},
        chartArea: {width: '80%', height: '70%'},
        backgroundColor: '#ffffff'
      };

      var chart = new google.visualization.ComboChart(document.getElementById('chart_div'));
      chart.draw(data, options);
    }
  </script>
</head>
<body style="margin:0; padding:20px; font-family:Arial; background:#f9f9f9;">
  <div id="chart_div" style="width:100%; height:550px;"></div>
  
  <!-- === SOTTO IL GRAFICO: source + link + logo === -->
  <p style="text-align:center; margin-top:15px; font-size:14px; color:#555;">
    Source: Google Sheets (aggiornato automaticamente)<br>
    <a href="https://commoditysupercycle.com/" target="_blank" style="color:#0066cc; text-decoration:none; font-weight:bold;">
      commoditysupercycle.com
    </a>
  </p>

